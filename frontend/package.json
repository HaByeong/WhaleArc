{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:test": "tsc -b && vite build --mode test --outDir dist-test",
    "build:prod": "tsc -b && vite build --mode production --outDir dist-prod",
    "lint": "eslint .",
    "preview": "vite preview",
    "serve:test": "vite preview --mode test --outDir dist-test --port 5174 --host",
    "serve:prod": "vite preview --mode production --outDir dist-prod --port 5173 --host"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.3.0",
    "@supabase/supabase-js": "^2.78.0",
    "axios": "^1.13.2",
    "lightweight-charts": "^5.1.0",
    "react": "^18.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.2",
    "recharts": "^3.5.0",
    "sockjs-client": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^18.3.0",
    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^14.0.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.9",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^5.4.2"
  }
}
