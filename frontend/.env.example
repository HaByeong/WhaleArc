# Vite는 mode별로 다른 파일을 읽습니다:
#   npm run dev         -> .env.development (로컬 백엔드 + test Supabase)
#   npm run build:test  -> .env.test        (test.whale-arc.com + test Supabase)
#   npm run build:prod  -> .env.production  (api.whale-arc.com + prod Supabase)
#
# 모든 .env* 파일은 .gitignore 에 의해 커밋되지 않습니다.
# 실제 값은 팀 내부에서 공유받아 로컬에 생성하세요.

VITE_API_BASE_URL=http://localhost:8080
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
